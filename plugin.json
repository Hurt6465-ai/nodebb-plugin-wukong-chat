{
  "id": "nodebb-plugin-wukong-chat",
  "name": "NodeBB Wukong Chat",
  "description": "Independent WuKongIM chat, conversation list, WebRTC calls, and topic-page chat core for NodeBB",
  "url": "https://bbs.886.best",
  "library": "./library.js",
  "hooks": [
    {
      "hook": "static:app.load",
      "method": "init"
    },
    {
      "hook": "filter:navigation.available",
      "method": "addNavigation"
    },
    {
      "hook": "action:user.create",
      "method": "onUserCreate"
    },
    {
      "hook": "filter:config.get",
      "method": "getConfig"
    }
  ],
  "templates": "templates",
  "staticDirs": {
    "static": "public"
  },
  "scripts": [
    "public/cp-harmony-call.js",
    "public/wukong-nav-redirect.js",
    "public/lib/topic-chat.js"
  ],
  "languages": "languages",
  "scss": [
    "scss/topic-chat-prehide.scss",
    "scss/topic-chat-ui.scss"
  ]
}
