<div id="nodebb-wukong-root"
     class="nbb-wk-root"
     data-wukong-root="1"
     data-target-uid="{targetUid}"
     data-tid="{tid}"
     data-channel-id="{channelId}"
     data-channel-type="{channelType}">
  <div class="nbb-wk-loading" data-i18n="loading_chat">Loading Wukong chat...</div>
</div>
<script>
window.__NBB_WUKONG_PAGE__ = {
  targetUid: "{targetUid}",
  tid: "{tid}",
  channelId: "{channelId}",
  channelType: "{channelType}"
};
</script>
<link rel="stylesheet" href="/plugins/nodebb-plugin-wukong-chat/static/wukong-chat.css?v=7" />
<script src="/plugins/nodebb-plugin-wukong-chat/static/wukong-chat.js?v=7"></script>
